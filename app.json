{
  "expo": {
    "name": "Sailinq",
    "slug": "sailinq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "sailinq",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/images/logo.png",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5FD9C4",
        "foregroundImage": "./assets/images/logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A1A2C",
          "image": "./assets/images/logo.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Sailinq potrzebuje dostępu do zdjęć, aby ustawić zdjęcie profilowe i zdjęcia rejsów."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
